{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensciflow.org/schemas/opensciflow-workflow-plan-v0.1.schema.json",
  "title": "OpenSciFlow Workflow Plan v0.1",
  "type": "object",
  "required": ["workflow_id", "task_type", "steps", "required_manifests", "expected_outputs", "limitations"],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "description"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "consumes": { "type": "array", "items": { "type": "string" } },
          "produces": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "required_manifests": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "optional_manifests": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

