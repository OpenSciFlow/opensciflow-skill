{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensciflow.org/schemas/opensciflow-execution-request-v0.1.schema.json",
  "title": "OpenSciFlow Execution Request v0.1",
  "type": "object",
  "required": [
    "workflow_id",
    "step_id",
    "manifest_id",
    "command_template_id",
    "command_source",
    "rendered_command",
    "inputs",
    "outputs",
    "run_directory",
    "environment",
    "dry_run",
    "approval_status"
  ],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "command_template_id": { "type": "string", "minLength": 1 },
    "command_source": {
      "type": "string",
      "enum": ["manifest-template", "workflow-template", "reviewed-wrapper"]
    },
    "rendered_command": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "(&&|\\|\\||;|`|\\$\\(|\\n|\\r)" }
    },
    "reviewed_wrapper": {
      "type": "object",
      "required": ["path", "review_status", "reviewed_by"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "review_status": { "type": "string", "enum": ["reviewed"] },
        "reviewed_by": { "type": "string", "minLength": 1 },
        "allowed_arguments": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "inputs": { "type": "array", "items": { "$ref": "#/$defs/io_file" } },
    "outputs": { "type": "array", "items": { "$ref": "#/$defs/io_file" } },
    "run_directory": { "type": "string", "minLength": 1 },
    "environment": { "type": "object" },
    "dry_run": { "type": "boolean" },
    "approval_status": {
      "type": "string",
      "enum": ["not-required", "pending", "approved", "rejected"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command_source": { "const": "reviewed-wrapper" }
        },
        "required": ["command_source"]
      },
      "then": {
        "required": ["reviewed_wrapper"]
      }
    }
  ],
  "$defs": {
    "io_file": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
