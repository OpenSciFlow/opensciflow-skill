{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensciflow.org/schemas/run-record-crosswalk-v0.1.schema.json",
  "title": "OpenSciFlow Run Record Crosswalk v0.1",
  "type": "object",
  "required": [
    "name",
    "source_schema",
    "target_schema",
    "source_required_fields",
    "target_required_fields",
    "field_mappings",
    "status_mappings",
    "alignment_notes"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "source_schema": { "type": "string", "minLength": 1 },
    "target_schema": { "type": "string", "minLength": 1 },
    "source_required_fields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_required_fields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "field_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "target", "rule"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "rule": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "status_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "alignment_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}

